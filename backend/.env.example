# Backend environment template for the qupick MCP server.
# Copy to .env and fill in real values. NO real secrets in this file — it is
# committed to git. Every var is read in src/backend/config.py.

# --- Required for production ---------------------------------------------------

# Postgres (Supabase session pooler, port 5432). Holds the API keys — TLS + backups.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Proton SMTP. SMTP_PASSWORD unset => emails only log to console (no key delivered).
SMTP_PASSWORD=
SMTP_USERNAME=noreply@quip.network
EMAIL_FROM=Qubitrefill <noreply@quip.network>

# Market data: "assets-api" (live) or "synthetic" (offline, deterministic).
MARKET_DATA_SOURCE=synthetic
ASSETS_API_BASE_URL=http://127.0.0.1:8080

# No Gurobi license in prod.
GUROBI_IN_RACE=0

# Internal HTTP port behind Caddy (Caddyfile upstream must match).
PORT=8000

# --- Optional / tuning ---------------------------------------------------------

SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_STARTTLS=true

# D-Wave Leap QPU competitor. Unset => SA-only (CPU).
DWAVE_API_TOKEN=
DWAVE_NUM_READS=500
DWAVE_ANNEAL_TIME_US=100
DWAVE_CHAIN_STRENGTH_PREFACTOR=3.0

# Client-side only (NOT the backend service): QUPICK_API_KEY and BITREFILL_API_KEY
# live in the qupick/bitrefill skill config, never here.
